# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js (Vercel: set AUTH_SECRET in Project → Environment Variables; optional NEXTAUTH_SECRET is supported)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Legacy name still supported if you already use it in Vercel:
# NEXTAUTH_SECRET="same-as-auth-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_URL="http://localhost:3000"
# On Vercel, AUTH_URL can be omitted — next.config infers https://YOUR_DEPLOYMENT.vercel.app from VERCEL_URL

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Upstash Redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Atlas Beauty <orders@atlasbeauty.com>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# App
ALLOWED_ORIGINS="http://localhost:3000"
APP_URL="http://localhost:3000"
